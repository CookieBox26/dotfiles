{
  "defaultMode": "dontAsk",
  "permissions": {
    "allow": [
      "Skill(ask)",
      "Bash(bash -c :*)",
      "WebFetch(domain:ar5iv.labs.arxiv.org)",
      "WebFetch(domain:arxiv.org)",
      "WebFetch(domain:dblp.org)",
      "WebFetch(domain:dl.acm.org)",
      "WebFetch(domain:docs.pytorch.org)",
      "WebFetch(domain:doi.org)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:html.mdpi.com)",
      "WebFetch(domain:ideas.repec.org)",
      "WebFetch(domain:jmlr.org)",
      "WebFetch(domain:jscs.jp)",
      "WebFetch(domain:neurips.cc)",
      "WebFetch(domain:onlinelibrary.wiley.com)",
      "WebFetch(domain:pierrepinson.com)",
      "WebFetch(domain:proceedings.mlr.press)",
      "WebFetch(domain:proceedings.neurips.cc)",
      "WebFetch(domain:pub.confit.atlas.jp)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:scholar.google.com)",
      "WebFetch(domain:scirev.org)",
      "WebFetch(domain:webcache.googleusercontent.com)",
      "WebFetch(domain:www.biometrics.gr.jp)",
      "WebFetch(domain:www.jfssa.jp)",
      "WebFetch(domain:www.letpub.com)",
      "WebFetch(domain:www.mdpi.com)",
      "WebFetch(domain:www.researchgate.net)",
      "WebFetch(domain:www.sciencedirect.com)",
      "WebFetch(domain:www.semanticscholar.org)",
      "WebFetch(domain:www.wiley.com)",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(curl:*)",
      "Bash(python:*)",
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'source ~/.claude/scripts/pre-bash-hook.sh'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -Command \"(New-Object Media.SoundPlayer 'C:\\Windows\\Media\\Ring01.wav').PlaySync()\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'source ~/.claude/scripts/post-proc.sh'"
          }
        ]
      }
    ]
  }
}

<!DOCTYPE HTML>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title></title>
<style type="text/css"><!--
:root {
  --border-color: #666;
  --link-color: #019386;
  --surface-color: color-mix(in srgb, var(--link-color) 21%, white);
  --btn-color: color-mix(in srgb, var(--link-color) 90%, white);
  --btn-text-color: var(--surface-color);
  --track-color: color-mix(in srgb, var(--link-color) 36%, white);
  --thumb-color: color-mix(in srgb, var(--link-color) 60%, white);
  --textarea-text-color: #444;
  --textarea-surface-color: #fff;
  --textarea-track-color: #ddd;
  --textarea-thumb-color: #aaa;
}
html, body {
  margin: 0;
  height: 100%;
}
body {
  font-size: 15px;
  line-height: 17px;
  font-family: "梅ゴシック", monospace;
  color: var(--border-color);
}
textarea {
  font-family: "梅ゴシック", monospace;
}
div#main {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  display: flex;
}
.area {
  box-sizing: border-box;
  width: 100%;
  height: 100%;
  background-color: var(--surface-color);
  scrollbar-color: var(--thumb-color) var(--track-color);
  padding: 8px;
  overflow-y: auto;
  white-space: nowrap;
}
div.left {
  flex: 0 0 auto;
  height: 100%;
  border-right: 2px solid var(--border-color);
}
div.right {
  flex: 1;
  height: 100%;
}
hr {
  box-sizing: border-box;
  width: 100%;
  border-style: none;
  border-top: 2px solid var(--border-color);
  margin: 6px 0;
}
textarea#note {
  background: var(--textarea-surface-color);
  color: var(--textarea-text-color);
  scrollbar-color: var(--textarea-thumb-color) var(--textarea-track-color);
  border: 0;
  outline: 0;
  resize: none;
  display: block;
  line-height: inherit;
  size: 14px;
  line-height: 16px;
}
a {
  display: block;
}
a, a:visited {
  color: var(--link-color);
  text-decoration: none;
}
a:hover {
  color: var(--link-color);
  text-decoration: underline;
}
.link {
  color: var(--link-color);
  cursor: pointer;
}
.link:hover {
  color: var(--link-color);
  text-decoration: underline;
}
.indent-1 {
  margin-left: 1em;
}
.indent-2 {
  margin-left: 2em;
}
span.btn {
  font-size: small;
  margin-left: 0.5em;
  padding: 0 0.2em;
  background-color: var(--btn-color);
  color: var(--btn-text-color);
  cursor: pointer;
}
span.cd::before {
  content: 'cd';
}
--></style>
<script type="text/javascript"><!--
const home = '../{{ .username }}/';
function createCopyButton() {
  let link = document.createElement('div');
  link.classList.add('link');
  link.innerHTML = 'Copy to clipboard';
  link.addEventListener('click', function(event) {
    const note = document.getElementById('note');
    navigator.clipboard.writeText(note.value);
  });
  return link;
}
function createSwitchButton(text, noteId) {
  let link = document.createElement('span');
  link.classList.add('link');
  link.innerHTML = text;
  link.addEventListener('click', function(event) {
    App.currentNoteId = noteId;
    localStorage.setItem('currentNoteId', noteId);
    note.value = localStorage.getItem(App.currentNoteId) || 'ご自由にメモを取ってください。';
  });
  return link;
}
function createLocalLink(text, path, indent='') {
  const container = document.createElement('div');
  const link = document.createElement('a');
  link.style.display = 'inline';
  if (indent) link.classList.add(indent);
  link.setAttribute('href', home + path);
  link.innerHTML = text;
  container.appendChild(link);
  if (path.endsWith('/')) {
    const span = document.createElement('span');
    span.classList.add('btn');
    span.classList.add('cd');
    span.addEventListener('click', function(event) {
      navigator.clipboard.writeText('cd ~/' + path);
    });
    container.appendChild(span);
  }
  return container;
}
function createLink(text, url, indent='') {
  const link = document.createElement('a');
  if (indent) link.classList.add(indent);
  link.setAttribute('href', url);
  link.innerHTML = text;
  return link;
}
function createLinkWithClipboard(text, url, clipBoard) {
  let link = document.createElement('div');
  link.classList.add('link');
  link.innerHTML = text;
  link.addEventListener('click', function(event) {
    navigator.clipboard.writeText(clipBoard);
    window.open(url, '_blank');
  });
  return link;
}
function createSpan(text) {
  let span = document.createElement('span');
  span.innerHTML = text;
  return span;
}
function setupSidebar0(appendSidebar) {
  appendSidebar(createSwitchButton('Note 0', 'note'));
  appendSidebar(createSpan(' | '));
  appendSidebar(createSwitchButton('1', 'note-1'));
  appendSidebar(createCopyButton());
  appendSidebar(document.createElement('hr'));
  appendSidebar(createLinkWithClipboard('AWS Sign-in', 'https://signin.aws.amazon.com/signin?client_id=arn%3Aaws%3Asignin%3A%3A%3Aconsole%2Fcanvas&redirect_uri=https%3A%2F%2Fconsole.aws.amazon.com%2Fconsole%2Fhome%3Fca-oauth-flow-id%3D27fc%26hashArgs%3D%2523%26isauthcode%3Dtrue%26nc2%3Dh_si%26src%3Dheader-signin%26state%3DhashArgsFromTB_us-east-2_c002fd7d256faf4f&page=resolve&code_challenge=7uKnomvSJggsVq5BKuhKSetpaik-QQQyzL93evF-vUg&code_challenge_method=SHA-256&backwards_compatible=true', '{{ .email }}'));
  appendSidebar(createLink('AWS Access Portal', '{{ .aws_sso_start_url }}'));
  appendSidebar(document.createElement('hr'));
  appendSidebar(createLink('GitHub', 'https://github.com/CookieBox26'));
  appendSidebar(createLink('Repositories', 'https://github.com/CookieBox26?tab=repositories', 'indent-1'));
  appendSidebar(createLink('dotfiles', 'https://github.com/CookieBox26/dotfiles/blob/main/README.md', 'indent-2'));
  appendSidebar(createLink('workspace', 'https://github.com/CookieBox26/workspace/blob/main/shelf/README.md', 'indent-2'));
  appendSidebar(createLink('nazuna', 'https://github.com/CookieBox26/nazuna/blob/main/README.md', 'indent-2'));
  appendSidebar(createLink('nazuna-bench', 'https://github.com/CookieBox26/nazuna-bench/blob/main/README.md', 'indent-2'));
  appendSidebar(createLink('cookies-site-utils', 'https://github.com/CookieBox26/cookies-site-utils/blob/main/README.md', 'indent-2'));
  appendSidebar(createLink('cookipedia', 'https://github.com/CookieBox26/cookipedia/blob/main/README.md', 'indent-2'));
  appendSidebar(createLink('cookie-box', 'https://github.com/CookieBox26/cookie-box/blob/main/README.md', 'indent-2'));
  appendSidebar(createLink('zuma', 'https://github.com/CookieBox26/zuma/blob/main/README.md', 'indent-2'));
  appendSidebar(createLink('Create a new Gist', 'https://gist.github.com/'));
  appendSidebar(document.createElement('hr'));
  appendSidebar(createLink('Slack', 'https://app.slack.com/client/{{ .slack }}'));
  appendSidebar(createLink('Yahoo!メール', 'https://mail.yahoo.co.jp/u/pc/f/'));
  appendSidebar(createLink('Googleドライブ', 'https://drive.google.com/drive/my-drive'));
  appendSidebar(createLink('はてなブログ', 'https://cookie-box.hatenablog.com/'));
  appendSidebar(createLink('はてなブログ管理', 'https://blog.hatena.ne.jp/'));
  appendSidebar(createLink('Qiita', 'https://qiita.com/CookieBox26'));
  appendSidebar(createLink('Copier Qiita', 'https://cookiebox26.github.io/ToyBox/misc/copier-qiita.html'));
  appendSidebar(createLink('ChatGPT', 'https://chatgpt.com/'));
  appendSidebar(createLink('Simplenote', 'https://app.simplenote.com/login/'));
}
function setupSidebar1(appendSidebar) {
  appendSidebar(createLink('Obsidian (Mercury)', 'obsidian://open?vault=Mercury'));
  appendSidebar(createLink('Obsidian (workspace)', 'obsidian://open?vault=workspace'));
  appendSidebar(document.createElement('hr'));
  appendSidebar(createLocalLink('Cookipedia α-version', 'workspace/cookipedia/docs/index.html'));
  appendSidebar(createLocalLink('カラーパレット', 'workspace/cookipedia/docs/utils/color_palette.html', 'indent-1'));
  appendSidebar(createLocalLink('Cookie Box', 'workspace/cookie-box/site/index.html'));
  appendSidebar(createLocalLink('Cookiepad', 'workspace/cookie-box/site/cookiepad/index.html', 'indent-1'));
  appendSidebar(createLink('http://127.0.0.1:8000/', 'http://127.0.0.1:8000/'));
  appendSidebar(document.createElement('hr'));
  appendSidebar(createLocalLink('chezmoi/', '.local/share/chezmoi/'));
  appendSidebar(createLocalLink('workspace/', 'workspace/'));
  appendSidebar(createLocalLink('CLAUDE.md', 'workspace/CLAUDE.md', 'indent-1'));
  appendSidebar(createLocalLink('shelf/', 'workspace/shelf/', 'indent-1'));
  appendSidebar(createLocalLink('nazuna/', 'workspace/nazuna/', 'indent-1'));
  appendSidebar(createLocalLink('cookipedia/', 'workspace/cookipedia/', 'indent-1'));
  appendSidebar(createLocalLink('cookie-box/', 'workspace/cookie-box/', 'indent-1'));
  appendSidebar(createLocalLink('square/', 'square/'));
  appendSidebar(createLocalLink('cookies-site-utils/', 'square/cookies-site-utils/', 'indent-1'));
  appendSidebar(createLocalLink('zuma/', 'square/zuma/', 'indent-1'));
}
function setupNote() {
  const note = document.getElementById('note');
  function saveNoteToLocalStorage() {
    localStorage.setItem(App.currentNoteId, note.value);
  }
  note.value = localStorage.getItem(App.currentNoteId) || 'ご自由にメモを取ってください。';
  note.addEventListener('input', saveNoteToLocalStorage);
}
function setupLinks() {
  const links = document.querySelectorAll('a');
  links.forEach((link) => {
    link.setAttribute('target', '_blank');
    link.setAttribute('rel', 'noopener noreferrer');
  });
}
document.addEventListener('DOMContentLoaded', () => {
  window.App = window.App || {};
  const v = localStorage.getItem('currentNoteId');
  App.currentNoteId = v === null ? 'note' : v;

  const sidebar0 = document.getElementById('sidebar-0');
  const appendSidebar0 = (elm) => sidebar0.appendChild(elm);
  setupSidebar0(appendSidebar0);

  const sidebar1 = document.getElementById('sidebar-1');
  const appendSidebar1 = (elm) => sidebar1.appendChild(elm);
  setupSidebar1(appendSidebar1);

  setupNote();
  setupLinks();
});
// --></script>
</head>
<body>
<div id="main">
  <div class="left">
    <div class="area" id="sidebar-0"></div>
  </div>
  <div class="left">
    <div class="area" id="sidebar-1"></div>
  </div>
  <div class="right">
    <textarea class="area" id="note" spellcheck="false"></textarea>
  </div>
</div>
</body>
</html>

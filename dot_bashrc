export LANG=ja_JP.UTF-8  # Set locale to Japanese (UTF-8)
export MSYS=winsymlinks:nativestrict  # Enable native symlink creation in Git Bash (MSYS)

alias neww='start "" "/c/Program Files/Git/bin/bash.exe"'
alias nppp='start "" "/c/Program Files/Notepad++/notepad++.exe"'
alias sakura='start "" "/c/Program Files (x86)/sakura/sakura.exe"'
alias chrome='start "" "/c/Program Files (x86)/Google/Chrome/Application/chrome.exe" $(pwd)'

alias chezcd='pushd ~/.local/share/chezmoi'
alias chezdiff='chezmoi diff | grep "^diff " | awk "{print \$3}"'
alias chezconf='sakura ~/.config/chezmoi/chezmoi.toml'

alias vcl='powershell -ExecutionPolicy Bypass -File "$(cygpath -w ~/.local/bin/VCL.ps1)"'

export REFPATH=~/Dropbox/obsidian/Mercury/References
alias refcd="cd $REFPATH"

export CLAUDE_CODE_DISABLE_GIT_INSTRUCTIONS=1

_claude_run() {
  local hid=0
  [ -e .git ] && {  mv .git .abc && hid=1; }
  [ "$hid" = 1 ] && ( sleep 10; mv .abc .git ) &
  command claude "$@"
}

claude_allowed_dirs=(
  "${HOME}/workspace"
  "${HOME}/Dropbox/obsidian/Mercury/References"
  "${HOME}/square/taiyaki"
)

claude() {
  local current_dir
  current_dir=$(pwd)
  for dir in "${claude_allowed_dirs[@]}"; do
    [ "$current_dir" = "$dir" ] && { _claude_run "$@"; return; }
  done
  echo 'このディレクトリでは claude の実行が想定されていません'
  read -p '本当に続行しますか？ (y/n): ' ans
  [ "$ans" = 'y' ] || { echo '中止します'; return; }
  _claude_run "$@"
}

_ssha() {
  local ssh_key="$1"
  local fp="$(ssh-keygen -lf "$ssh_key" | awk '{print $2}')"
  if ssh-add -l 2>/dev/null | grep -q "$fp"; then
    echo "鍵は既に追加されています"
    return
  fi
  echo "鍵を追加します"
  eval "$(ssh-agent -s)"
  ssh-add "$ssh_key"
}

ssha() {
  _ssha "${HOME}/.ssh/id_ed25519"
}

git() {
  case "${1-}" in
    pull|push)
      ssha
      ;;
  esac
  command git "$@"
}
